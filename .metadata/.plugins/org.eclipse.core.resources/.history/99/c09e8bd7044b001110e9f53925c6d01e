@charset "UTF-8";

/* =========================================
   CHECKOUT PAGE
========================================= */

body{

    background:
        radial-gradient(circle at top left,#163c78 0%,transparent 25%),
        radial-gradient(circle at bottom right,#1e3a8a 0%,transparent 25%),
        linear-gradient(135deg,#020617,#0f172a,#111827);

    color:#ffffff;
}

/* =========================================
   MAIN CONTAINER
========================================= */

.checkout-container{

    width:92%;

    max-width:1400px;

    margin:auto;

    padding:120px 0 60px;
}

/* =========================================
   TITLE
========================================= */

.checkout-title{

    font-size:52px;

    font-weight:800;

    margin-bottom:40px;
}

/* =========================================
   LAYOUT
========================================= */

.checkout-layout{

    display:grid;

    grid-template-columns:
        2fr 1fr;

    gap:32px;

    align-items:start;
}

/* =========================================
   LEFT / RIGHT
========================================= */

.checkout-left,
.checkout-right{

    width:100%;
}

/* =========================================
   GLASS CARD
========================================= */

.card{

    background:
        rgba(255,255,255,0.05);

    border:
        1px solid rgba(255,255,255,0.08);

    border-radius:28px;

    padding:30px;

    backdrop-filter:blur(18px);

    box-shadow:
        0 10px 30px rgba(0,0,0,0.25);

    margin-bottom:28px;
}

/* =========================================
   CARD TITLE
========================================= */

.card h2{

    font-size:28px;

    margin-bottom:24px;

    color:#ffffff;
}

/* =========================================
   FORM GROUP
========================================= */

.form-group{

    display:flex;

    flex-direction:column;

    gap:10px;

    margin-bottom:24px;
}

.form-group label{

    font-size:15px;

    font-weight:600;

    color:#ffffff;
}

/* =========================================
   INPUTS
========================================= */

input,
textarea,
select{

    width:100%;

    padding:16px;

    border:none;

    outline:none;

    border-radius:16px;

    background:
        rgba(255,255,255,0.06);

    color:#ffffff;

    font-size:15px;

    border:
        1px solid rgba(255,255,255,0.08);

    transition:0.3s ease;
}

input:focus,
textarea:focus,
select:focus{

    border-color:#3b82f6;

    box-shadow:
        0 0 0 4px rgba(59,130,246,0.15);
}

/* PLACEHOLDER */

input::placeholder,
textarea::placeholder{

    color:#94a3b8;
}

/* TEXTAREA */

textarea{

    min-height:120px;

    resize:none;
}

/* SELECT OPTIONS */

select option{

    background:#0f172a;
}

/* =========================================
   ROW
========================================= */

.row{

    display:grid;

    grid-template-columns:
        repeat(2,1fr);

    gap:20px;
}

/* =========================================
   PAYMENT OPTIONS
========================================= */

.payment-option{

    display:flex;

    align-items:center;

    gap:12px;

    padding:16px;

    border-radius:16px;

    background:
        rgba(255,255,255,0.04);

    border:
        1px solid rgba(255,255,255,0.06);

    margin-bottom:14px;

    cursor:pointer;

    transition:0.3s ease;
}

.payment-option:hover{

    background:
        rgba(255,255,255,0.08);
}

.payment-option input{

    width:auto;
}

/* =========================================
   SUMMARY
========================================= */

.summary-item{

    display:flex;

    justify-content:space-between;

    margin-bottom:18px;

    font-size:16px;

    color:#cbd5e1;
}

.summary-total{

    display:flex;

    justify-content:space-between;

    margin-top:24px;

    padding-top:20px;

    border-top:
        1px solid rgba(255,255,255,0.08);

    font-size:24px;

    font-weight:700;

    color:#22c55e;
}

/* =========================================
   BUTTON
========================================= */

.place-order-btn{

    width:100%;

    height:58px;

    border:none;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            #2563eb,
            #7c3aed
        );

    color:#ffffff;

    font-size:17px;

    font-weight:700;

    cursor:pointer;

    transition:0.3s ease;

    margin-top:20px;
}

.place-order-btn:hover{

    transform:translateY(-2px);

    box-shadow:
        0 14px 28px rgba(37,99,235,0.35);
}

/* =========================================
   STICKY SUMMARY
========================================= */

.checkout-right{

    position:sticky;

    top:110px;
}

/* =========================================
   RESPONSIVE
========================================= */

@media(max-width:992px){

    .checkout-layout{

        grid-template-columns:1fr;
    }

    .checkout-right{

        position:relative;

        top:0;
    }
}

@media(max-width:768px){

    .checkout-title{

        font-size:38px;
    }

    .row{

        grid-template-columns:1fr;
    }

    .card{

        padding:24px;
    }
}


/* =========================================
   SUCCESS PAGE
========================================= */

.success-page{

    min-height:80vh;

    display:flex;

    align-items:center;

    justify-content:center;

    padding:60px 20px;
}

/* CARD */

.success-card{

    width:100%;

    max-width:700px;

    background:
        rgba(255,255,255,0.05);

    border:
        1px solid rgba(255,255,255,0.08);

    border-radius:32px;

    padding:50px;

    text-align:center;

    backdrop-filter:blur(18px);

    box-shadow:
        0 15px 40px rgba(0,0,0,0.35);
}

/* ICON */

.success-icon{

    width:110px;
    height:110px;

    margin:auto;

    border-radius:50%;

    background:
        linear-gradient(
            135deg,
            #22c55e,
            #16a34a
        );

    display:flex;

    align-items:center;

    justify-content:center;

    color:#ffffff;

    font-size:52px;

    font-weight:800;

    margin-bottom:30px;

    box-shadow:
        0 10px 30px rgba(34,197,94,0.35);
}

/* TITLE */

.success-card h1{

    font-size:46px;

    margin-bottom:18px;

    color:#ffffff;
}

/* MESSAGE */

.success-card p{

    color:#cbd5e1;

    font-size:18px;

    line-height:1.8;

    margin-bottom:36px;
}

/* INFO BOX */

.success-info{

    background:
        rgba(255,255,255,0.04);

    border-radius:24px;

    padding:24px;

    margin-bottom:34px;
}

/* ROW */

.success-row{

    display:flex;

    justify-content:space-between;

    padding:14px 0;

    border-bottom:
        1px solid rgba(255,255,255,0.08);

    color:#ffffff;
}

.success-row:last-child{

    border-bottom:none;
}

/* BUTTONS */

.success-actions{

    display:flex;

    gap:18px;

    justify-content:center;

    flex-wrap:wrap;
}

/* BUTTON */

.success-btn,
.track-btn{

    padding:16px 30px;

    border-radius:18px;

    text-decoration:none;

    color:#ffffff;

    font-weight:700;

    transition:0.3s ease;
}

.success-btn{

    background:
        linear-gradient(
            135deg,
            #2563eb,
            #7c3aed
        );
}

.track-btn{

    background:
        linear-gradient(
            135deg,
            #22c55e,
            #16a34a
        );
}

.success-btn:hover,
.track-btn:hover{

    transform:translateY(-3px);
}

/* RESPONSIVE */

@media(max-width:768px){

    .success-card{

        padding:36px 24px;
    }

    .success-card h1{

        font-size:34px;
    }

    .success-actions{

        flex-direction:column;
    }
}