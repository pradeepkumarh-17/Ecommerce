@charset "UTF-8";
.account-page{

    width:90%;

    max-width:1200px;

    margin:60px auto;

    color:#ffffff;
}

.account-page h1{

    font-size:42px;

    margin-bottom:30px;
}

.account-card{

    background:
        rgba(255,255,255,0.05);

    border:
        1px solid rgba(255,255,255,0.08);

    border-radius:28px;

    padding:40px;

    backdrop-filter:blur(18px);
}

.profile-item{

    display:flex;

    justify-content:space-between;

    padding:18px 0;

    border-bottom:
        1px solid rgba(255,255,255,0.08);
}

.profile-item strong{

    color:#93c5fd;
}