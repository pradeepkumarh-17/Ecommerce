body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f5f5f5;
}

/* HEADER */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 40px;
    background: white;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.logo {
    font-size: 26px;
    font-weight: bold;
    color: #28a745;
}

.search-bar input {
    padding: 8px;
}

.nav-links a {
    margin-left: 20px;
    text-decoration: none;
    color: #333;
}

/* HERO */
.hero {
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)),
    url("https://images.unsplash.com/photo-1503341455253-b2e723bb3db");

    background-size: cover;
    background-position: center;

    height: 300px;
    margin: 20px;
    border-radius: 12px;

    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
}

.btn {
    padding: 10px 20px;
    background: white;
    color: #28a745;
    border-radius: 5px;
    text-decoration: none;
}

/* CATEGORY */
.categories {
    text-align: center;
}

.category-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
}

.category-card {
    background: white;
    padding: 15px 25px;
    border-radius: 10px;
    text-decoration: none;
    color: black;
}

/* PRODUCTS */
.products {
    padding: 30px;
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
}

.product-card {
    background: white;
    padding: 15px;
    border-radius: 10px;
    text-align: center;
}

.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.price {
    color: #28a745;
    font-weight: bold;
}

.cart-btn {
    background: #28a745;
    color: white;
    border: none;
    padding: 10px;
    width: 100%;
}

/* FOOTER */
.footer {
    text-align: center;
    padding: 20px;
    background: #222;
    color: white;
}