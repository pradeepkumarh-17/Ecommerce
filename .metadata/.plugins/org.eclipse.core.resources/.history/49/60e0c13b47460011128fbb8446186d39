@charset "UTF-8";

/* FULL PAGE BACKGROUND */
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #1abc9c, #3498db);
    height: 100vh;
}

/* CENTER CONTAINER */
.auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
}

/* GLASS CARD */
.auth-box {
    width: 360px;
    padding: 35px;
    border-radius: 15px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    color: white;
    text-align: center;
}

/* TITLE */
.auth-box h2 {
    margin-bottom: 20px;
    font-weight: 600;
}

/* INPUT FIELDS */
.auth-box input {
    width: 100%;
    margin: 12px 0;
    padding: 12px;
    border-radius: 8px;
    border: none;
    outline: none;
    font-size: 14px;
}

/* INPUT FOCUS EFFECT */
.auth-box input:focus {
    box-shadow: 0 0 5px #00ffcc;
}

/* BUTTON */
.auth-box button {
    width: 100%;
    padding: 12px;
    margin-top: 10px;
    border: none;
    border-radius: 8px;
    background: #2ecc71;
    color: white;
    font-size: 16px;
    cursor: pointer;
    transition: 0.3s;
}

/* BUTTON HOVER */
.auth-box button:hover {
    background: #27ae60;
}

/* REGISTER LINK */
.auth-box a {
    color: #fff;
    text-decoration: underline;
    display: inline-block;
    margin-top: 15px;
}

/* ERROR */
.error {
    color: #ff6b6b;
    margin-bottom: 10px;
}