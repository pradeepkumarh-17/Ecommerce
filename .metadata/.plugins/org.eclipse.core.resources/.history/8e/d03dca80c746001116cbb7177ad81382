@charset "UTF-8";

/* ================= PAGE TITLE ================= */
h2 {
    margin: 20px;
    font-size: 28px;
    font-weight: 600;
}

/* ================= PRODUCT GRID ================= */
.product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    padding: 20px;
}

/* ================= PRODUCT CARD ================= */
.product-card {
    background: #fff;
    padding: 15px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    position: relative;
}

.product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

/* ================= IMAGE ================= */
.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
}

/* ================= NAME ================= */
.product-card h3 {
    font-size: 16px;
    margin: 10px 0;
    color: #333;
}

/* ================= PRICE ================= */
.price {
    font-size: 18px;
    font-weight: bold;
    color: #28a745;
    margin-bottom: 10px;
}

/* ================= BUTTON ================= */
.cart-btn {
    width: 100%;
    padding: 10px;
    background: #28a745;
    border: none;
    color: white;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    transition: 0.2s;
}

.cart-btn:hover {
    background: #218838;
}

/* ================= LINK ================= */
.product-link {
    text-decoration: none;
    color: inherit;
    display: block;
}

/* ================= FILTER ================= */
.filter-section {
    padding: 10px 20px;
}

.filter-section form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.filter-section input,
.filter-section select {
    padding: 8px;
    border-radius: 6px;
    border: 1px solid #ddd;
}

/* ================= CART TABLE ================= */
table {
    width: 90%;
    margin: 20px auto;
    border-collapse: collapse;
    background: white;
}

table th {
    background: #f5f5f5;
    padding: 12px;
    text-align: left;
}

table td {
    padding: 10px;
    border-bottom: 1px solid #eee;
}

table tr:hover {
    background: #fafafa;
}

/* ================= TOTAL ================= */
h3 {
    text-align: right;
    margin: 20px;
    font-size: 22px;
}

/* ================= EMPTY MESSAGE ================= */
.no-data {
    text-align: center;
    padding: 20px;
    font-size: 18px;
    color: #777;
}

/* ================= RESPONSIVE ================= */
@media (max-width: 992px) {
    .product-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {
    .product-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 480px) {
    .product-grid {
        grid-template-columns: repeat(1, 1fr);
    }
}

/* ================= PRODUCT DETAILS ================= */
.product-details {
    display: flex;
    gap: 40px;
    padding: 30px;
    background: white;
    border-radius: 10px;
}

.image-section img {
    width: 350px;
    border-radius: 10px;
}

.info-section {
    flex: 1;
}

.info-section .price {
    font-size: 24px;
    margin-bottom: 15px;
}

/* ================= RATING ================= */
.rating {
    margin: 10px 0;
    font-size: 18px;
}

/* ================= DESCRIPTION ================= */
.desc {
    margin: 15px 0;
    color: #555;
}

/* ================= OPTIONS ================= */
.option {
    margin: 15px 0;
}

.color-box {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    margin-left: 10px;
    cursor: pointer;
}

.size-box {
    display: inline-block;
    padding: 5px 10px;
    border: 1px solid #ddd;
    margin-left: 10px;
    cursor: pointer;
}

/* ================= BIG BUTTON ================= */
.big-btn {
    width: 100%;
    margin-top: 20px;
}

/* ================= REVIEWS ================= */
