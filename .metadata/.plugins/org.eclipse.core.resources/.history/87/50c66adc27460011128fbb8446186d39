/* ================= GLOBAL ================= */
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: #f5f5f5;
}

.container {
    max-width: 1200px;
    margin: auto;
}

/* ================= HEADER ================= */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 40px;
    background: white;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.logo {
    font-size: 26px;
    font-weight: bold;
    color: #28a745;
}

.search-bar {
    display: flex;
}

.search-bar input {
    padding: 10px;
    width: 300px;
    border: 1px solid #ddd;
    border-radius: 5px 0 0 5px;
}

.search-bar button {
    padding: 10px 15px;
    border: none;
    background: #28a745;
    color: white;
    border-radius: 0 5px 5px 0;
    cursor: pointer;
}

.nav-links a {
    margin-left: 20px;
    text-decoration: none;
    color: #333;
    font-weight: 500;
}

/* ================= HERO (UPDATED WITH ONLINE IMAGE) ================= */
.hero {
    height: 320px;
    margin: 20px;
    border-radius: 12px;

    background: 
        linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
        url('https://images.unsplash.com/photo-1521334884684-d80222895322?q=80&w=1600');

    background-size: cover;
    background-position: center;

    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
}

.hero h1 {
    font-size: 42px;
    margin-bottom: 10px;
}

.hero p {
    font-size: 18px;
}

/* BUTTON */
.btn {
    display: inline-block;
    margin-top: 15px;
    padding: 12px 25px;
    background: white;
    color: #28a745;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
    transition: 0.3s;
}

.btn:hover {
    background: #28a745;
    color: white;
}

/* ================= CATEGORY ================= */
.categories {
    padding: 30px;
    text-align: center;
}

.category-grid {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
}

.category-card {
    background: white;
    padding: 20px 30px;
    border-radius: 12px;
    box-shadow: 0 3px 8px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: 0.3s;
    text-decoration: none;
    color: #333;
    font-weight: 500;
}

.category-card:hover {
    transform: translateY(-5px);
    background: #28a745;
    color: white;
}

/* ================= PRODUCTS ================= */
.products {
    padding: 30px;
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 25px;
}

/* PRODUCT CARD */
.product-card {
    background: white;
    padding: 15px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    cursor: pointer;
}

/* HOVER EFFECT */
.product-card:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

/* IMAGE */
.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
    transition: transform 0.3s;
}

/* IMAGE ZOOM */
.product-card:hover img {
    transform: scale(1.08);
}

/* TEXT */
.product-card h3 {
    margin: 10px 0;
    font-size: 16px;
}

/* PRICE */
.price {
    font-weight: bold;
    color: #28a745;
    margin-bottom: 10px;
}

/* BUTTON */
.cart-btn {
    width: 100%;
    padding: 10px;
    background: #28a745;
    border: none;
    color: white;
    border-radius: 6px;
    cursor: pointer;
    transition: 0.3s;
}

.cart-btn:hover {
    background: #218838;
}

/* ================= FOOTER ================= */
.footer {
    text-align: center;
    padding: 20px;
    background: #222;
    color: white;
    margin-top: 40px;
}

/* ================= RESPONSIVE ================= */
@media (max-width: 768px) {
    .search-bar input {
        width: 150px;
    }

    .category-grid {
        flex-wrap: wrap;
    }
}