@charset "UTF-8";

/* 🔥 MAIN CONTAINER FIX (header overlap issue) */
.checkout-container {
    padding: 100px 30px 30px; /* was 30px → FIXED */
}

/* 🔥 LAYOUT FIX */
.checkout-layout {
    display: flex;
    gap: 30px;
    align-items: flex-start; /* IMPORTANT */
}

/* LEFT SIDE */
.checkout-left {
    flex: 2;
    min-width: 0; /* prevents cutting */
}

/* RIGHT SIDE (SUMMARY FIX) */
.checkout-right {
    flex: 1;
    position: sticky;   /* keeps it aligned */
    top: 100px;         /* below header */
}

/* CARD */
.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* TEXTAREA */
textarea {
    width: 100%;
    height: 100px;
    padding: 10px;
    margin-top: 10px;
    border: 1px solid #ddd;
    border-radius: 6px;
}

/* 🔥 INPUT ROW FIX */
.row {
    display: flex;
    gap: 15px; /* increased for better spacing */
    margin-top: 10px;
}

.row input {
    flex: 1;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 6px;
}

/* PAYMENT */
.payment-option {
    display: block;
    margin: 10px 0;
    font-size: 16px;
}

/* SUMMARY */
.summary h2 {
    color: #28a745;
    margin-top: 10px; /* 🔥 fix spacing */
}

/* BUTTON */
.place-order-btn {
    width: 100%;
    padding: 12px;
    background: #28a745;
    color: white;
    border: none;
    border-radius: 6px;
    margin-top: 15px;
    cursor: pointer;
}

.place-order-btn:hover {
    background: #218838;
}