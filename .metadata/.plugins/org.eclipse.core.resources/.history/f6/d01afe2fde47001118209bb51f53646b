<%@ page contentType="text/html; charset=UTF-8"%>

<%
    // ✅ GET CART FROM SESSION (Map based)
    java.util.Map<Integer, Integer> cart =
        (java.util.Map<Integer, Integer>) session.getAttribute("cart");

    int cartCount = 0;

    if (cart != null) {
        for (int qty : cart.values()) {
            cartCount += qty;   // ✅ total quantity
        }
    }
%>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LuxCommerce | Premium E-Store</title>

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
	href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap"
	rel="stylesheet">

<!-- CSS -->
<link rel="stylesheet"
	href="<%= request.getContextPath() %>/assets/css/style.css">
<link rel="stylesheet"
	href="<%= request.getContextPath() %>/assets/css/modern-ui.css">

<!-- GSAP -->
<script
	src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script
	src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>

<body>

	<header class="header">

		<!-- LOGO -->
		<div class="logo">
			LUX<span>STORE</span>
		</div>

		<!-- SEARCH BAR -->
		<div class="search-bar">
			<form action="<%= request.getContextPath() %>/product" method="GET">
				<input type="text" name="search"
					placeholder="Discover premium products...">
				<button type="submit">🔍</button>
			</form>
		</div>

		<!-- NAVIGATION -->
		<nav class="nav-links">
			<a href="<%= request.getContextPath() %>/views/user/home.jsp">Home</a>
			<a href="<%= request.getContextPath() %>/product">Products</a>

			<!-- ✅ CART WITH LIVE COUNT -->
			<a href="<%= request.getContextPath() %>/cart" class="cart-link">
				🛒 Cart <% if(cartCount > 0){ %> <span class="cart-badge"><%= cartCount %></span>
				<% } %>
			</a> <a href="<%= request.getContextPath() %>/login" class="login-btn">Login</a>
		</nav>

	</header>