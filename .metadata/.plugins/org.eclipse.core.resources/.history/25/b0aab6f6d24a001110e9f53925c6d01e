<%@ page contentType="text/html; charset=UTF-8" %>

<%
    // ✅ GET CART FROM SESSION (Map based)
    java.util.Map<Integer, Integer> cart =
        (java.util.Map<Integer, Integer>) session.getAttribute("cart");

    int cartCount = 0;

    if (cart != null) {
        for (int qty : cart.values()) {
            cartCount += qty;   // total items count
        }
    }
%>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ECommerce | Premium E-Store</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="<%= request.getContextPath() %>/assets/css/style.css">
    <link rel="stylesheet" href="<%= request.getContextPath() %>/assets/css/modern-ui.css">

    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <!-- ✅ CART BADGE STYLE -->
    <style>
        .cart-link {
            position: relative;
            display: inline-block;
            font-weight: 500;
        }

        /* 🔴 Superscript-style badge */
        .cart-badge {
            position: absolute;
            top: -6px;
            right: -10px;

            background: red;
            color: white;

            font-size: 10px;
            font-weight: bold;

            padding: 2px 6px;
            border-radius: 50%;

            min-width: 16px;
            text-align: center;

            box-shadow: 0 0 6px rgba(255,0,0,0.6);
        }
    </style>
</head>

<body>

<header class="header">

    <!-- LOGO -->
    <div class="logo">
        E<span>STORE</span>
    </div>

    <!-- SEARCH -->
    <div class="search-bar">
        <form action="<%= request.getContextPath() %>/product" method="GET">
            <input type="text" name="search" placeholder="Discover premium products...">
            <button type="submit">🔍</button>
        </form>
    </div>

    <!-- NAV -->
    <nav class="nav-links">
        <a href="<%= request.getContextPath() %>/views/user/home.jsp">Home</a>
        <a href="<%= request.getContextPath() %>/product">Products</a>

        <!-- 🛒 CART WITH SUPERSCRIPT BADGE -->
        <a href="<%= request.getContextPath() %>/cart" class="cart-link">
            🛒 Cart
            <% if(cartCount > 0){ %>
                <span class="cart-badge"><%= cartCount %></span>
            <% } %>
        </a>

        <a href="<%= request.getContextPath() %>/login" class="login-btn">Login</a>
    </nav>

</header>