<%@ page contentType="text/html; charset=UTF-8" %>

<%
    // =========================================
    // GET CART FROM SESSION
    // =========================================

    java.util.Map<Integer, Integer> cart =
        (java.util.Map<Integer, Integer>)
        session.getAttribute("cart");

    int cartCount = 0;

    if (cart != null) {

        for (int qty : cart.values()) {

            cartCount += qty;
        }
    }

    // =========================================
    // USER SESSION
    // =========================================

    Object loggedUser =
            session.getAttribute("user");

    String userName =
            (String) session.getAttribute("userName");
%>

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>

        CloudCart | Premium Ecommerce

    </title>

    <!-- GOOGLE FONT -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap"
          rel="stylesheet">

    <!-- CSS -->

    <link rel="stylesheet"
          href="<%= request.getContextPath() %>/assets/css/style.css">

    <link rel="stylesheet"
          href="<%= request.getContextPath() %>/assets/css/modern-ui.css">

    <!-- GSAP -->

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <!-- HEADER STYLES -->

    <style>

        .cart-link {

            position: relative;

            display: inline-block;
        }

        .cart-badge {

            position: absolute;

            top: -6px;
            right: -10px;

            background: #ef4444;

            color: white;

            font-size: 10px;

            font-weight: bold;

            padding: 2px 6px;

            border-radius: 50%;

            min-width: 16px;

            text-align: center;
        }

        /* AUTH BUTTONS */

        .login-btn,
        .register-btn {

            padding: 10px 18px;

            border-radius: 12px;

            text-decoration: none;

            font-weight: 600;

            transition: 0.3s ease;
        }

        .login-btn {

            background:
                linear-gradient(
                    135deg,
                    #2563eb,
                    #1d4ed8
                );

            color: #ffffff !important;
        }

        .login-btn:hover {

            transform: translateY(-2px);

            box-shadow:
                0 10px 20px rgba(37,99,235,0.35);
        }

        .register-btn {

            background:
                linear-gradient(
                    135deg,
                    #7c3aed,
                    #9333ea
                );

            color: #ffffff !important;
        }

        .register-btn:hover {

            transform: translateY(-2px);

            box-shadow:
                0 10px 20px rgba(124,58,237,0.35);
        }

        /* USER */

        .user-pill {

            padding: 10px 16px;

            border-radius: 14px;

            background:
                rgba(255,255,255,0.08);

            color: #ffffff;

            font-weight: 600;
        }

    </style>

</head>

<body>

<header class="header">

    <!-- LOGO -->

    <div class="logo">

        LUX<span>STORE</span>

    </div>

    <!-- SEARCH -->

    <div class="search-bar">

        <form action="<%= request.getContextPath() %>/product"
              method="GET">

            <input type="text"
                   name="search"

                   placeholder="Discover premium products...">

            <button type="submit">

                🔍

            </button>

        </form>

    </div>

    <!-- NAVIGATION -->

    <nav class="nav-links">

        <!-- HOME -->

        <a href="<%= request.getContextPath() %>/views/user/home.jsp">

            Home

        </a>

        <!-- PRODUCTS -->

        <a href="<%= request.getContextPath() %>/product">

            Products

        </a>

        <!-- CART -->

        <a href="<%= request.getContextPath() %>/cart"
           class="cart-link">

            🛒 Cart

            <% if(cartCount > 0){ %>

                <span class="cart-badge">

                    <%= cartCount %>

                </span>

            <% } %>

        </a>

        <!-- AUTH -->

        <% if(loggedUser == null){ %>

            <!-- LOGIN -->

            <a href="<%= request.getContextPath() %>/auth?action=login"
               class="login-btn">

                Login

            </a>

            <!-- REGISTER -->

            <a href="<%= request.getContextPath() %>/auth?action=register"
               class="register-btn">

                Register

            </a>

        <% } else { %>

            <!-- USER -->

            <span class="user-pill">

                👤 <%= userName %>

            </span>

        <% } %>

    </nav>

</header>