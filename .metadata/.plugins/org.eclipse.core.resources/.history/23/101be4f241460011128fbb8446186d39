/* ===== FIX CATEGORY ALIGNMENT ===== */
.category-grid {
    display: flex !important;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
}

.category-card {
    display: inline-block;
    padding: 12px 25px;
    background: white;
    border-radius: 10px;
    text-decoration: none;
    color: #333;
    font-weight: 500;
    box-shadow: 0 3px 8px rgba(0,0,0,0.1);
    transition: 0.3s;
}

.category-card:hover {
    background: #28a745;
    color: white;
}

/* ===== FIX PRODUCT GRID ===== */
.product-grid {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    padding: 20px;
}

/* ===== FIX PRODUCT CARD ===== */
.product-card {
    background: white;
    padding: 15px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    transition: 0.3s;
    width: 100%;
}

.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
}

/* ===== BUTTON FIX ===== */
.cart-btn {
    margin-top: 10px;
}

/* ===== REMOVE HORIZONTAL SCROLL ===== */
.products {
    overflow: hidden;
}