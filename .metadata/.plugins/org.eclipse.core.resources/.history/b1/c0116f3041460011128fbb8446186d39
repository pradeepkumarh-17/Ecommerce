.hero {
    height: 320px;
    margin: 20px;
    border-radius: 12px;

    background:
        linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
        url('https://images.unsplash.com/photo-1521334884684-d80222895322?q=80&w=1600');

    background-size: cover;
    background-position: center;

    display: flex;
    justify-content: center;
    align-items: center;
}

.hero-content {
    text-align: center;
}