/* INPUT FOCUS */
.auth-box input {
    width: 100%;
    box-sizing: border-box; /* 👈 VERY IMPORTANT */
}
/* BUTTON */
.auth-box button {
    width: 100%;
    padding: 14px;
    background: #ef1d1d;
    color: white;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;

    display: flex;
    justify-content: center;
    align-items: center;

    margin: 20px auto 10px auto; /* 👈 CENTER FIX */
    text-align: center;
}
/* BUTTON HOVER */
.auth-box button:hover {
    background: #b91c1c; /* darker red */
}

/* SWITCH TEXT */
.switch {
    margin-top: 15px;
    font-size: 14px;
    color: #374151;
}

/* SWITCH LINK */
.switch a {
    color: #2563eb;
    font-weight: 600;
    text-decoration: none;
}

.switch a:hover {
    text-decoration: underline;
}

/* BACK HOME */
.back-home {
    display: block;
    margin-top: 15px;
    text-decoration: none;
    color: #6b7280;
    font-size: 14px;
}

.back-home:hover {
    color: #111827;
}

