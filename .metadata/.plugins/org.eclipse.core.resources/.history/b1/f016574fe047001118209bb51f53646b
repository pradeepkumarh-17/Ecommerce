body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    height: 100vh;
}

/* CENTER */
.auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
}

/* CARD */
.auth-box {
    width: 350px;
    padding: 30px;
    background: #ffffff; /* clean white for contrast */
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    text-align: center;
}

/* TITLE */
.auth-box h2 {
    margin-bottom: 10px;
    color: #1e293b; /* dark navy */
}

/* SUBTITLE */
.subtitle {
    color: #6b7280; /* soft gray */
    font-size: 14px;
    margin-bottom: 15px;
}

/* INPUT */
.auth-box input {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border-radius: 8px;
    border: 1px solid #d1d5db;
    font-size: 14px;
    transition: 0.3s;
}

/* INPUT FOCUS */
.auth-box input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 5px rgba(59,130,246,0.3);
    outline: none;
}

