@charset "UTF-8";

.checkout-container {
    padding: 30px;
}

.checkout-layout {
    display: flex;
    gap: 30px;
}

.checkout-left {
    flex: 2;
}

.checkout-right {
    flex: 1;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

textarea {
    width: 100%;
    height: 100px;
    padding: 10px;
    margin-top: 10px;
    border: 1px solid #ddd;
    border-radius: 6px;
}

.row {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.row input {
    flex: 1;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 6px;
}

.payment-option {
    display: block;
    margin: 10px 0;
    font-size: 16px;
}

.summary h2 {
    color: #28a745;
}

.place-order-btn {
    width: 100%;
    padding: 12px;
    background: #28a745;
    color: white;
    border: none;
    border-radius: 6px;
    margin-top: 15px;
    cursor: pointer;
}

.place-order-btn:hover {
    background: #218838;
}