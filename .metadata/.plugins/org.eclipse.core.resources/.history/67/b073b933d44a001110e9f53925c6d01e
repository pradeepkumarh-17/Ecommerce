@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;

    background:
        radial-gradient(circle at top left,#1e3a8a 0%,transparent 25%),
        radial-gradient(circle at bottom right,#7c3aed 0%,transparent 25%),
        linear-gradient(135deg,#020617,#0f172a,#111827);

    color:#ffffff;

    overflow-x:hidden;
}

/* =========================================
   CONTAINER
   ========================================= */

.container{
    width:95%;
    max-width:1500px;

    margin:auto;

    padding:40px 0;
}

/* =========================================
   FILTER
   ========================================= */

.filter-wrapper{
    margin-bottom:60px;
}

.filter-header{
    margin-bottom:30px;
}

.filter-header h1{
    font-size:64px;

    font-weight:800;

    margin-bottom:12px;
}

.filter-header p{
    font-size:18px;

    color:#cbd5e1;

    max-width:700px;

    line-height:1.8;
}

/* FILTER BAR */

.lux-filter-bar{

    display:grid;

    grid-template-columns:
        2fr
        1fr
        1fr
        1fr
        auto;

    gap:20px;

    background:
        rgba(255,255,255,0.05);

    padding:30px;

    border-radius:30px;

    border:
        1px solid rgba(255,255,255,0.08);

    backdrop-filter:blur(18px);

    align-items:end;
}

.filter-group{
    display:flex;

    flex-direction:column;

    gap:10px;
}

.filter-group label{
    font-size:14px;

    font-weight:600;
}

.filter-group input,
.filter-group select{

    height:58px;

    padding:0 18px;

    border-radius:16px;

    border:
        1px solid rgba(255,255,255,0.08);

    background:
        rgba(255,255,255,0.04);

    color:#ffffff;

    outline:none;

    font-size:15px;
}

.filter-group input:focus,
.filter-group select:focus{

    border-color:#3b82f6;

    box-shadow:
        0 0 0 4px rgba(59,130,246,0.15);
}

.filter-group select option{
    background:#0f172a;
}

/* FILTER BUTTON */

.filter-btn{

    height:58px;

    padding:0 30px;

    border:none;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            #f59e0b,
            #f97316
        );

    color:#ffffff;

    font-size:15px;

    font-weight:700;

    cursor:pointer;

    transition:0.3s ease;
}

.filter-btn:hover{

    transform:translateY(-3px);

    box-shadow:
        0 12px 28px rgba(249,115,22,0.35);
}

/* =========================================
   PRODUCT GRID
   ========================================= */

.product-grid{

    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(320px,1fr));

    gap:32px;
}

/* PRODUCT CARD */

.product-card{

    background:
        rgba(255,255,255,0.05);

    border-radius:28px;

    overflow:hidden;

    border:
        1px solid rgba(255,255,255,0.08);

    backdrop-filter:blur(16px);

    transition:0.35s ease;

    box-shadow:
        0 10px 30px rgba(0,0,0,0.25);
}

.product-card:hover{

    transform:
        translateY(-8px);

    box-shadow:
        0 18px 40px rgba(0,0,0,0.35);
}

/* IMAGE */

.product-img-wrapper{

    width:100%;

    height:340px;

    overflow:hidden;
}

.product-img-wrapper img{

    width:100%;
    height:100%;

    object-fit:cover;

    transition:0.4s ease;
}

.product-card:hover img{

    transform:scale(1.05);
}

/* CONTENT */

.product-content{

    padding:24px;
}

/* PRODUCT NAME */

.product-name{

    font-size:24px;

    font-weight:700;

    margin-bottom:8px;
}

/* BRAND */

.product-brand{

    color:#93c5fd;

    font-size:14px;

    margin-bottom:16px;
}

/* PRICE */

.price-row{

    display:flex;

    align-items:center;

    gap:14px;

    margin-bottom:14px;
}

.discount-price{

    color:#22c55e;

    font-size:28px;

    font-weight:700;
}

.original-price{

    color:#94a3b8;

    text-decoration:line-through;
}

/* RATING */

.rating-row{

    display:flex;

    align-items:center;

    gap:10px;

    margin-bottom:20px;
}

.stars{

    color:#facc15;
}

.rating-text{

    color:#cbd5e1;

    font-size:14px;
}

/* BUTTONS */

.product-actions{

    display:flex;

    gap:12px;
}

.view-btn,
.cart-btn{

    flex:1;

    text-align:center;

    padding:14px;

    border-radius:14px;

    text-decoration:none;

    font-weight:600;

    border:none;

    cursor:pointer;

    transition:0.3s ease;
}

/* VIEW BUTTON */

.view-btn{

    background:
        rgba(255,255,255,0.08);

    color:#ffffff;
}

.view-btn:hover{

    background:
        rgba(255,255,255,0.15);
}

/* CART BUTTON */

.cart-btn{

    background:
        linear-gradient(
            135deg,
            #2563eb,
            #7c3aed
        );

    color:#ffffff;
}

.cart-btn:hover{

    transform:translateY(-2px);
}

/* NO DATA */

.no-data-panel{

    width:100%;

    text-align:center;

    padding:80px 20px;
}

.no-data-panel h2{

    font-size:38px;

    margin-bottom:12px;
}

.no-data-panel p{

    color:#cbd5e1;
}

/* =========================================
   RESPONSIVE
   ========================================= */

@media(max-width:1200px){

    .lux-filter-bar{

        grid-template-columns:
            repeat(2,1fr);
    }
}

@media(max-width:768px){

    .lux-filter-bar{

        grid-template-columns:1fr;
    }

    .filter-header h1{

        font-size:42px;
    }

    .product-grid{

        grid-template-columns:1fr;
    }
}