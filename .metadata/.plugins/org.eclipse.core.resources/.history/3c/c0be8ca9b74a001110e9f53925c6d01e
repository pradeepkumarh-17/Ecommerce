/* =========================================================
   LUXSTORE AUTH UI
   Premium Ecommerce Authentication Design
   ========================================================= */

/* GOOGLE FONT */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

/* RESET */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

/* BODY */
body{
    font-family:'Poppins',sans-serif;
    min-height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;

    padding:20px;

    overflow:auto;

    background:
        radial-gradient(circle at top left,#2563eb 0%,transparent 28%),
        radial-gradient(circle at bottom right,#7c3aed 0%,transparent 25%),
        linear-gradient(135deg,#020617,#0f172a,#111827);

    position:relative;
}

/* GLOW EFFECTS */
body::before,
body::after{
    content:'';

    position:absolute;

    width:420px;
    height:420px;

    border-radius:50%;

    filter:blur(140px);

    opacity:0.22;

    z-index:0;
}

body::before{
    background:#2563eb;

    top:-120px;
    left:-120px;
}

body::after{
    background:#9333ea;

    bottom:-120px;
    right:-120px;
}

/* CONTAINER */
.auth-container{
    width:100%;

    display:flex;
    justify-content:center;
    align-items:center;

    position:relative;
    z-index:2;
}

/* AUTH CARD */
.auth-box{
    width:430px;

    padding:42px 34px;

    border-radius:30px;

    background:rgba(255,255,255,0.08);

    backdrop-filter:blur(22px);
    -webkit-backdrop-filter:blur(22px);

    border:1px solid rgba(255,255,255,0.10);

    box-shadow:
        0 10px 40px rgba(0,0,0,0.35),
        inset 0 1px 1px rgba(255,255,255,0.08);

    text-align:center;

    animation:fadeIn 0.8s ease;
}

/* CARD ANIMATION */
@keyframes fadeIn{
    from{
        opacity:0;
        transform:translateY(30px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }
}

/* LOGO */
.logo{
    font-size:42px;
    font-weight:700;

    letter-spacing:1px;

    margin-bottom:12px;

    color:#f8fafc;
}

.logo span{
    color:#60a5fa;
}

/* TITLE */
.auth-box h2{
    font-size:36px;
    font-weight:600;

    color:#ffffff;

    margin-bottom:10px;
}

/* SUBTITLE */
.subtitle{
    color:#cbd5e1;

    font-size:14px;
    line-height:1.6;

    margin-bottom:28px;
}

/* FORM */
.auth-box form{
    display:flex;
    flex-direction:column;
    gap:18px;
}

/* INPUT GROUP */
.input-group{
    width:100%;
}

/* INPUT */
.auth-box input{
    width:100%;

    padding:16px 18px;

    border-radius:16px;

    border:1px solid rgba(255,255,255,0.10);

    background:rgba(255,255,255,0.07);

    color:#ffffff;

    font-size:15px;
    font-weight:400;

    outline:none;

    transition:all 0.3s ease;
}

/* PLACEHOLDER */
.auth-box input::placeholder{
    color:#cbd5e1;
}

/* INPUT FOCUS */
.auth-box input:focus{
    border-color:#3b82f6;

    background:rgba(255,255,255,0.09);

    box-shadow:
        0 0 0 4px rgba(59,130,246,0.15),
        0 0 20px rgba(59,130,246,0.20);

    transform:translateY(-2px);
}

/* BUTTON */
.auth-box button{
    width:100%;

    padding:16px;

    margin-top:6px;

    border:none;
    outline:none;

    border-radius:16px;

    background:linear-gradient(
        135deg,
        #2563eb,
        #7c3aed
    );

    color:#ffffff;

    font-size:16px;
    font-weight:600;

    cursor:pointer;

    transition:all 0.35s ease;

    box-shadow:
        0 12px 25px rgba(37,99,235,0.30);
}

/* BUTTON HOVER */
.auth-box button:hover{
    transform:translateY(-3px);

    box-shadow:
        0 16px 35px rgba(124,58,237,0.35);
}

/* BUTTON ACTIVE */
.auth-box button:active{
    transform:scale(0.98);
}

/* ERROR BOX */
.error{
    background:rgba(220,38,38,0.14);

    border:1px solid rgba(220,38,38,0.25);

    color:#fecaca;

    padding:12px;

    border-radius:14px;

    font-size:14px;
}

/* SWITCH */
.switch{
    margin-top:24px;

    color:#cbd5e1;

    font-size:14px;
}

/* LINKS */
.switch a,
.back-home{
    color:#60a5fa;

    text-decoration:none;

    font-weight:500;

    transition:0.3s ease;
}

.switch a:hover,
.back-home:hover{
    color:#ffffff;
}

/* BACK HOME */
.back-home{
    display:inline-block;

    margin-top:16px;

    font-size:14px;
}

/* RESPONSIVE */
@media(max-width:500px){

    .auth-box{
        width:100%;
        padding:34px 24px;
    }

    .logo{
        font-size:34px;
    }

    .auth-box h2{
        font-size:28px;
    }

    .subtitle{
        font-size:13px;
    }
}