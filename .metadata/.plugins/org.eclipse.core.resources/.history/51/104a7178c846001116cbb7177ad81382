@charset "UTF-8";

.cart-container {
    padding: 30px;
}

.cart-layout {
    display: flex;
    gap: 30px;
}

.cart-items {
    flex: 2;
}

.cart-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: white;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.cart-card img {
    width: 100px;
    border-radius: 10px;
}

.cart-info h3 {
    margin: 0;
}

.price {
    color: #28a745;
    font-weight: bold;
}

.remove-btn {
    color: red;
    text-decoration: none;
    font-size: 14px;
}

.subtotal {
    margin-left: auto;
    font-weight: bold;
}

/* RIGHT SIDE */
.cart-summary {
    flex: 1;
    background: white;
    padding: 20px;
    border-radius: 10px;
    height: fit-content;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.checkout-btn {
    width: 100%;
    padding: 12px;
    background: #28a745;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    margin-top: 15px;
}

.checkout-btn:hover {
    background: #218838;
}